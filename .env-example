# Transport: "stdio" (default, for local MCP clients) or "streamable-http" (for remote/deployment)
# MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=streamable-http)
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# CHM help files: JSON dict mapping app -> {source_name -> path}
GABOS_CHM_FILES='{"MyApp": {"Admin Manual": "/path/to/admin.chm", "End User Manual": "/path/to/user.chm"}, "another_app": {"Reference": "/path/to/reference.chm"}}'

# Optional: override cache directory (default: platform-specific, e.g. ~/.cache/gabos-mcp/chm on Linux)
# GABOS_CHM_CACHE_DIR=/custom/cache/path
